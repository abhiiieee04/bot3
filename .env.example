# Copy these into Railway → Variables tab
# Do NOT commit real values to git

# ── Bot ──────────────────────────────────────────────────────────────────────
# From @BotFather
BOT_TOKEN=your_bot_token_here

# ── Chat IDs (numeric, starts with -100) ─────────────────────────────────────
# Private channels/groups only have numeric IDs — no @username
# Get these by adding @userinfobot to each chat
CHANNEL_ID=-1001234567890
GROUP_ID=-1009876543210

# ── Private Invite Links ──────────────────────────────────────────────────────
# Generate inside Telegram:
#   Channel: Channel Info → Invite Links → Create New Link → copy https://t.me/+ link
#   Group:   Group Info   → Invite Links → Create New Link → copy https://t.me/+ link
CHANNEL_INVITE=https://t.me/+xxxxxxxxxxxxxx
GROUP_INVITE=https://t.me/+yyyyyyyyyyyyyy

# ── Database ──────────────────────────────────────────────────────────────────
# Injected automatically by Railway when you add a Postgres plugin
# Do NOT set this manually on Railway — it's auto-provided
DATABASE_URL=postgresql://user:password@host:5432/railway
